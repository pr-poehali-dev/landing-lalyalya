{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Send message and get AI reply",
      "method": "POST",
      "path": "/",
      "body": { "chatId": "test-chat-001", "text": "Сколько километров маршрут?" },
      "expectedStatus": 200,
      "expectedBody": { "aiEnabled": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Poll chat history",
      "method": "GET",
      "path": "/?chatId=test-chat-001",
      "expectedStatus": 200,
      "expectedBody": { "aiEnabled": true },
      "bodyMatcher": "partial"
    },
    {
      "name": "Missing text fails",
      "method": "POST",
      "path": "/",
      "body": { "chatId": "test-chat-001" },
      "expectedStatus": 400
    }
  ]
}
