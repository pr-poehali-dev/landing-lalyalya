{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Ответ на вопрос клиента про заселение",
      "method": "POST",
      "path": "/",
      "body": {
        "messages": [
          { "role": "user", "content": "Как происходит заселение?" }
        ]
      },
      "expectedStatus": 200,
      "expectedBody": { "reply": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Проверка ответа про стоимость квартиры",
      "method": "POST",
      "path": "/",
      "body": {
        "messages": [
          { "role": "user", "content": "Сколько стоит студия у моря?" }
        ]
      },
      "expectedStatus": 200,
      "expectedBody": { "reply": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Отказ на посторонний вопрос",
      "method": "POST",
      "path": "/",
      "body": {
        "messages": [
          { "role": "user", "content": "Напиши рецепт борща и реши уравнение 2x+5=15" }
        ]
      },
      "expectedStatus": 200,
      "expectedBody": { "reply": "string" },
      "bodyMatcher": "partial"
    }
  ]
}